# ─── Data Provider API Keys ─────────────────────
FRED_API_KEY=
FMP_API_KEY=
NEWSAPI_API_KEY=
ALPHAVANTAGE_API_KEY=
TWELVEDATA_API_KEY=
SEC_USER_AGENT="YourName your@email.com"
TAVILY_API_KEY=
# TAVILY_SEARCH_DEPTH=basic
EXA_API_KEY=
# EXA_SEARCH_TYPE=auto

# ─── LLM Provider API Keys ─────────────────────
# Z.ai (primary for all agents)
ZAI_API_KEY=
# ZHIPU_API_KEY=
# BIGMODEL_API_KEY=
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Cerebras (default)
CEREBRAS_API_KEY=
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Groq (fallback)
GROQ_API_KEY=

# Gemini (fallback)
# Either GOOGLE_API_KEY or GEMINI_API_KEY works
GOOGLE_API_KEY=
# GEMINI_API_KEY=

# OpenAI (legacy fallback, optional)
# OPENAI_API_KEY=

# ─── Per-Agent Model Overrides (optional) ───────
# ORCH_MODEL=openai/gpt-oss-20b
# MACRO_MODEL=llama-3.1-8b-instant
# FUNDA_MODEL=llama-3.1-8b-instant
# SENTI_MODEL=llama-3.1-8b-instant
# QUANT_MODEL=llama-3.1-8b-instant
# RISK_MODEL=openai/gpt-oss-20b
# REPORT_MODEL=gemini-2.5-flash-lite

# ─── Global LLM Routing (default) ──────────────
LLM_PROVIDER=cerebras
LLM_MODEL_NAME=gpt-oss-120b

# ─── Optional Tuning ────────────────────────────
# HTTP_TIMEOUT_SEC=20
# CACHE_DIR=.cache
# CACHE_TTL_SEC=3600
# RATE_LIMIT_QPS=2
# LLM_MAX_CONCURRENCY=1
# LLM_FORCE_REAL_IN_TESTS=1
